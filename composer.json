{
    "name": "stellarwp/slic",
    "description": "StellarWP Local Interactive Containers - containerized testing environment CLI tool for WordPress plugins, themes, and projects.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "StellarWP\\Slic\\Test\\": "tests/",
          "StellarWP\\Slic\\Test\\Support\\": "tests/_support"
        }
    },
    "config": {
        "sort-packages": true
    }
}
